# Liquidity or Liquidation - serverless env (set these in the Vercel project,
# NOT in any committed file). Copy to .env.local for local `vercel dev`.

# Reuse the existing GGE website Supabase project.
SUPABASE_URL=https://your-project.supabase.co
# Service role key - server-side only, never ships to the browser.
SUPABASE_SERVICE_KEY=your-service-role-key

# Salt for hashing IPs in the rate-limit table (any long random string).
RATE_SALT=change-me-to-a-long-random-string

# Token for the admin DELETE path (remove a handle from the board).
# Send as the X-Admin-Token header. Leave blank to disable admin delete.
ADMIN_TOKEN=change-me

# Comma-separated origins allowed to call the API (CORS).
ALLOWED_ORIGINS=https://liquidity-or-liquidation.vercel.app,http://localhost:3000

# Optional: extra banned handle substrings, comma-separated.
# BLOCK_EXTRA=word1,word2
